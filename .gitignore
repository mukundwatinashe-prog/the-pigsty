# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/
backend/public/
dist/
dist-ssr/

# Uploaded files (feed receipts, etc.)
uploads/

# Environment & secrets
.env
.env.local
.env.*.local
vercel-env-import.txt
backend/.env
frontend/.env
# VPS deploy secrets (app env + Postgres password) — never commit
deploy/api.env
deploy/.env
*client_secret*.json
# Vercel env exports / production secret dumps (never commit)
.env.vercel.*
.env.vercel.production*
# Plaintext credential/recovery files (never commit — keep these in a secret manager)
*recovery_code*.txt
*2FA*.txt

# Local scratch / reference (not app source)
/IMG-*.jpg*
/feed_report.xlsx

# Local ops scripts that connect to production and contain demo credentials — never commit
backend/scripts/seed-demo-data.mjs
backend/scripts/create-demo-user.mjs
backend/scripts/verify-free-blocked.mjs

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS & editors
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local databases
backend/prisma/*.db
backend/prisma/*.db-journal

# TypeScript cache
*.tsbuildinfo
frontend/node_modules/.tmp/

# Optional local assets
*.local
.vercel
