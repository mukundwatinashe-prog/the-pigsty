# Optional: Google Analytics 4 measurement ID (enables gtag + config in main.tsx)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: overrides default agape@magnaagape.com for mailto links and UI copy (server inbox: CONTACT_INBOX_EMAIL in backend/.env)
# VITE_SUPPORT_EMAIL=hello@yourfarmapp.com
# Google Sign-In button on login/register — must match backend GOOGLE_CLIENT_ID (Web application client ID)
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# WhatsApp chat link (digits only: country code + number, no + or spaces), e.g. Zimbabwe 263771234567
# VITE_WHATSAPP_E164=263771234567
