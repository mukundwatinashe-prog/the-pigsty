generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  FARM_MANAGER
  WORKER
}

enum PigBreed {
  LARGE_WHITE
  LANDRACE
  DUROC
  PIETRAIN
  BERKSHIRE
  HAMPSHIRE
  CHESTER_WHITE
  YORKSHIRE
  TAMWORTH
  MUKOTA
  KOLBROEK
  WINDSNYER
  SA_LANDRACE
  INDIGENOUS
  CROSSBREED
  OTHER
}

enum PigStage {
  BOAR
  SOW
  GILT
  WEANER
  PIGLET
  PORKER
  GROWER
  FINISHER
}

enum PigStatus {
  ACTIVE
  SOLD
  DECEASED
  QUARANTINE
}

enum HealthStatus {
  HEALTHY
  SICK
  UNDER_TREATMENT
  RECOVERED
}

enum PigObservationCategory {
  GENERAL_WELLBEING
  APPETITE_FEED_INTAKE
  BEHAVIOUR_ACTIVITY
  RESPIRATORY_COUGHING
  DIGESTIVE_DIARRHEA
  SKIN_LESIONS
  LAMENESS_MOBILITY
  EYES_NOSE_DISCHARGE
  OTHER
}

enum PenType {
  FARROWING
  GROWER
  FINISHER
  BOAR
  QUARANTINE
  NURSERY
}

enum FarmPlan {
  FREE
  PRO
}

enum FeedType {
  MAIZE_CRECHE
  SOYA
  PREMIX
  CONCENTRATE
  LACTATING
  WEANER
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String?
  name              String
  phone             String?
  /** E.164-style digits only; unique when set — used for lookup & SMS reset */
  phoneNormalized   String?  @unique @map("phone_normalized")
  photo             String?
  mfaEnabled   Boolean  @default(false)
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmMemberships FarmMember[]
  weightLogs      WeightLog[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  feedPurchases   FeedPurchase[]
  feedDailyUsages FeedDailyUsage[]
  pigObservations PigObservation[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Farm {
  id                   String    @id @default(uuid())
  name                 String
  logoUrl              String?
  location             String
  country              String
  currency             String    @default("USD")
  timezone             String    @default("UTC")
  weightUnit           String    @default("kg")
  pricePerKg           Decimal   @default(3.3) @db.Decimal(10, 2)
  fiscalYearStart      Int       @default(1)
  plan                 FarmPlan  @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  isDeleted            Boolean   @default(false)
  feedLowStockThresholdKg Decimal? @db.Decimal(10, 2)
  /** Optional default bucket amounts per feed type — pre-fills "Log daily feed" for new days */
  feedDefaultDailyBuckets Json?
  /** KG = feedPurchasePrices are per kg; TONNE = prices are per metric tonne (1000 kg) */
  feedPurchasePriceUnit String @default("KG") @db.VarChar(10)
  /** Per-feed-type price in farm currency; unit determined by feedPurchasePriceUnit */
  feedPurchasePrices Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  members    FarmMember[]
  pigs       Pig[]
  pens       Pen[]
  auditLogs  AuditLog[]
  importLogs ImportLog[]
  saleRecords SaleRecord[]
  feedPurchases FeedPurchase[]
  feedDailyUsages FeedDailyUsage[]

  @@map("farms")
}

model FarmMember {
  id     String @id @default(uuid())
  userId String
  farmId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, farmId])
  @@map("farm_members")
}

model Pen {
  id       String  @id @default(uuid())
  farmId   String
  name     String
  type     PenType
  capacity Int

  farm Farm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  pigs Pig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, name])
  @@map("pens")
}

model Pig {
  id              String       @id @default(uuid())
  farmId          String
  tagNumber       String
  name            String?
  breed           PigBreed
  stage           PigStage
  dateOfBirth     DateTime?
  acquisitionDate DateTime
  entryWeight     Decimal      @db.Decimal(10, 2)
  currentWeight   Decimal      @db.Decimal(10, 2)
  status          PigStatus    @default(ACTIVE)
  healthStatus    HealthStatus @default(HEALTHY)
  serviced        Boolean      @default(false)
  servicedDate    DateTime?
  /** Date pig was weaned — used for weaners/gilts to estimate return-to-heat window */
  weanedDate      DateTime?
  /** When staff recorded the ~21-day post-service heat check */
  serviceHeatCheckAt DateTime?
  /** true = observed in heat; false = checked, not in heat; null = not yet recorded */
  serviceHeatInHeat Boolean?
  penId           String?
  damId           String?
  sireId          String?
  notes           String?
  photo           String?

  farm  Farm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  pen   Pen?  @relation(fields: [penId], references: [id], onDelete: SetNull)
  dam   Pig?  @relation("DamOffspring", fields: [damId], references: [id], onDelete: SetNull)
  sire  Pig?  @relation("SireOffspring", fields: [sireId], references: [id], onDelete: SetNull)

  damOffspring  Pig[] @relation("DamOffspring")
  sireOffspring Pig[] @relation("SireOffspring")

  weightLogs       WeightLog[]
  vaccinations     Vaccination[]
  farrowingRecords FarrowingRecord[]
  saleRecords      SaleRecord[]
  observations     PigObservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, tagNumber])
  @@map("pigs")
}

model PigObservation {
  id       String                 @id @default(uuid())
  pigId    String
  userId   String
  category PigObservationCategory
  notes    String?

  pig  Pig  @relation(fields: [pigId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([pigId, createdAt])
  @@map("pig_observations")
}

model WeightLog {
  id     String   @id @default(uuid())
  pigId  String
  userId String
  weight Decimal  @db.Decimal(10, 2)
  date   DateTime
  notes  String?

  pig  Pig  @relation(fields: [pigId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("weight_logs")
}

model Vaccination {
  id               String    @id @default(uuid())
  pigId            String
  name             String
  batchNumber      String?
  dateAdministered DateTime
  nextDueDate      DateTime?
  administeredBy   String?

  pig Pig @relation(fields: [pigId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("vaccinations")
}

model FarrowingRecord {
  id              String    @id @default(uuid())
  pigId           String
  farrowingDate   DateTime
  pigletsBornAlive Int
  pigletsBornDead  Int      @default(0)
  pigletsWeaned   Int?
  weaningDate     DateTime?
  /** Average birth weight per piglet (farm weight unit) */
  avgBirthWeightKg Decimal? @db.Decimal(10, 3)
  ironDate        DateTime?
  tailDockedDate  DateTime?
  teatClippedDate DateTime?
  notes           String?

  pig Pig @relation(fields: [pigId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([pigId, farrowingDate])
  @@map("farrowing_records")
}

enum SaleType {
  LIVE_SALE
  SLAUGHTER
}

model SaleRecord {
  id          String   @id @default(uuid())
  pigId       String
  farmId      String
  saleType    SaleType
  saleDate    DateTime
  weightAtSale Decimal @db.Decimal(10, 2)
  pricePerKg  Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  buyer       String?
  notes       String?

  pig  Pig  @relation(fields: [pigId], references: [id], onDelete: Cascade)
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([farmId, saleDate])
  @@map("sale_records")
}

model AuditLog {
  id       String @id @default(uuid())
  userId   String
  farmId   String
  action   String
  entity   String
  entityId String
  details  String?

  user User @relation(fields: [userId], references: [id])
  farm Farm @relation(fields: [farmId], references: [id])

  createdAt DateTime @default(now())

  @@index([farmId, createdAt])
  @@map("audit_logs")
}

model ImportLog {
  id           String @id @default(uuid())
  farmId       String
  fileName     String
  totalRows    Int
  importedRows Int
  errorRows    Int
  status       String
  errors       String?

  farm Farm @relation(fields: [farmId], references: [id])

  createdAt DateTime @default(now())

  @@map("import_logs")
}

model Lead {
  id        String   @id @default(uuid())
  email     String
  firstName String?
  lastName  String?
  phone     String?
  subject   String?
  message   String?
  source    String   @default("landing")
  userId    String?
  farmId    String?
  createdAt DateTime @default(now())

  @@map("leads")
}

model FeedPurchase {
  id          String    @id @default(uuid())
  farmId      String
  feedType    FeedType
  quantityKg  Decimal   @db.Decimal(12, 3)
  totalCost   Decimal   @db.Decimal(12, 2)
  supplier    String?
  purchasedAt DateTime
  receiptKey  String
  createdById String?

  farm      Farm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([farmId, purchasedAt])
  @@map("feed_purchases")
}

model FeedDailyUsage {
  id                 String   @id @default(uuid())
  farmId             String
  usageDate          DateTime @db.Date
  maizeBuckets       Decimal  @default(0) @db.Decimal(12, 4)
  soyaBuckets        Decimal  @default(0) @db.Decimal(12, 4)
  premixBuckets      Decimal  @default(0) @db.Decimal(12, 4)
  concentrateBuckets Decimal  @default(0) @db.Decimal(12, 4)
  lactatingBuckets   Decimal  @default(0) @db.Decimal(12, 4)
  weanerBuckets      Decimal  @default(0) @db.Decimal(12, 4)
  notes              String?
  userId             String
  submittedAt        DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, usageDate])
  @@index([farmId, usageDate])
  @@map("feed_daily_usage")
}
