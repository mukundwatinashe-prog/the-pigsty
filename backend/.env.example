DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pigtrack_pro?schema=public"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
# Comma-separated allowed origins. In development, localhost and 127.0.0.1 on any port are also accepted.
CORS_ORIGIN="http://localhost:5173"
# Used by Stripe checkout/portal redirects (no trailing path)
FRONTEND_URL="http://localhost:5173"
# Stripe billing (optional). Webhook: POST /api/billing/webhook with raw body — see server.ts
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_GROWER=""
STRIPE_PRICE_ID_ENTERPRISE=""
STRIPE_PRODUCT_ID_GROWER="prod_ULoYq6GTHBDaf3"
STRIPE_PRODUCT_ID_ENTERPRISE="prod_UclYhlEo7MhV2u"
# Google Sign-In: create an OAuth 2.0 Web client ID; server verifies ID tokens (POST /api/auth/google { "idToken": "..." }).
# Use the same client ID in the frontend: VITE_GOOGLE_CLIENT_ID=...  Authorized JavaScript origins: e.g. http://localhost:5173
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# AI assistant config (openai | claude | gemini)
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
CLAUDE_API_KEY=""
CLAUDE_MODEL="claude-3-5-haiku-latest"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
AI_RATE_LIMIT_WINDOW_MS="900000"
AI_RATE_LIMIT_MAX_REQUESTS="30"
# Auth uses HttpOnly cookies (path /api). Frontend and API must be same-site in the browser, or configure cookie domain / SameSite for your deployment.
#
# Contact form + signup alerts are emailed to this inbox via the email Worker (see contactNotify.service.ts).
CONTACT_INBOX_EMAIL="pigfarm@the-pigsty.org"
# Legacy Gmail SMTP — optional fallback; password reset and contact now use CLOUDFLARE_EMAIL_WORKER_URL.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="The Pigsty <noreply@the-pigsty.org>"
#
# Cloudflare email Worker (see email-worker/). User-facing mail (welcome, upgrade,
# team invites) is sent through this Worker, which relays to Resend.
# If CLOUDFLARE_EMAIL_WORKER_URL is unset, these emails are logged to the console instead.
CLOUDFLARE_EMAIL_WORKER_URL=""
EMAIL_WORKER_TOKEN=""
EMAIL_FROM="The Pigsty <noreply@the-pigsty.org>"
#
# Password reset SMS (optional). If unset, reset codes are logged to the server console in development.
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""   # E.164, e.g. +15551234567
