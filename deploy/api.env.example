# Copy to `api.env` on the VPS and fill from your existing Vercel production env.
# NOTE: do NOT set DATABASE_URL here — docker-compose points the app at the local
# Postgres container. Everything else mirrors the Vercel env.

# --- Auth (required) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- URLs / CORS ---
NODE_ENV=production
CORS_ORIGIN=https://the-pigsty.org,https://www.the-pigsty.org
FRONTEND_URL=https://the-pigsty.org

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_GROWER=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_PRODUCT_ID_GROWER=
STRIPE_PRODUCT_ID_ENTERPRISE=

# --- AI ---
AI_PROVIDER=claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX_REQUESTS=30

# --- Email (Cloudflare Worker -> Resend, or Resend direct) ---
CLOUDFLARE_EMAIL_WORKER_URL=
EMAIL_WORKER_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=The Pigsty <noreply@the-pigsty.org>
CONTACT_INBOX_EMAIL=pigfarm@the-pigsty.org
PLATFORM_ADMIN_EMAILS=

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Cloudflare R2 (feed receipts + DB backups) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Cloudflare Turnstile ---
TURNSTILE_SECRET_KEY=

# --- Backups ---
BACKUP_RETAIN_DAYS=14
